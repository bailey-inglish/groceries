// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   String             @id @default(cuid())
  email                String             @unique
  name                 String?
  passwordHash         String
  householdSize        Int                @default(1)
  dietaryRestrictions  String             @default("[]")
  openAiKey            String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  inventoryItems       InventoryItem[]
  stockEvents          StockEvent[]
  recipes              Recipe[]
  shoppingListItems    ShoppingListItem[]
}

model Product {
  id               String          @id @default(cuid())
  barcode          String          @unique
  name             String
  brand            String?
  category         String?
  imageUrl         String?
  nutritionDataJson String?
  createdAt        DateTime        @default(now())

  inventoryItems   InventoryItem[]
}

model InventoryItem {
  id             String             @id @default(cuid())
  userId         String
  productId      String?
  barcode        String?
  name           String
  brand          String?
  quantity       Float              @default(1)
  unit           String             @default("count")
  location       String             @default("PANTRY")
  category       String?
  expirationDate DateTime?
  notes          String?
  imageUrl       String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  product         Product?           @relation(fields: [productId], references: [id])
  stockEvents     StockEvent[]
  shoppingItems   ShoppingListItem[]
}

model StockEvent {
  id              String        @id @default(cuid())
  inventoryItemId String
  userId          String
  eventType       String        // SCAN_IN / SCAN_OUT / MANUAL_ADJUST
  quantityChange  Float
  notes           String?
  createdAt       DateTime      @default(now())

  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Recipe {
  id           String   @id @default(cuid())
  userId       String
  title        String
  description  String?
  ingredients  String   @default("[]")
  instructions String
  servings     Int      @default(4)
  prepTimeMin  Int      @default(0)
  cookTimeMin  Int      @default(0)
  tags         String   @default("[]")
  source       String   @default("USER")
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ShoppingListItem {
  id                  String         @id @default(cuid())
  userId              String
  inventoryItemId     String?
  name                String
  quantity            Float          @default(1)
  unit                String         @default("count")
  isPurchased         Boolean        @default(false)
  predictedRunOutDate DateTime?
  createdAt           DateTime       @default(now())

  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  inventoryItem       InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
}
